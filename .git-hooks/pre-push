#!/bin/sh
# Pre-push hook: runs tests and build before allowing push.
# Auto-configured via `npm install` (package.json "prepare" script).
# To bypass in emergencies: git push --no-verify

echo "Running tests..."
npm test || {
  echo "Tests failed. Push aborted."
  exit 1
}

echo "Running build..."
npm run build || {
  echo "Build failed. Push aborted."
  exit 1
}

echo "All checks passed."
