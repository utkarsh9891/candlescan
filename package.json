{
  "name": "candlescan",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bash scripts/start.sh",
    "dev": "bash scripts/start.sh",
    "build": "vite build",
    "preview": "vite preview",
    "pages:deploy": "bash scripts/deploy-to-pages.sh",

    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",

    "simulate:run": "node scripts/simulate-day.mjs",

    "cockpit:start": "node scripts/cockpit/index.mjs",
    "cockpit:stop": "node scripts/cockpit/cli.mjs stop",
    "cockpit:init": "node scripts/cockpit/cli.mjs init",
    "cockpit:status": "node scripts/cockpit/cli.mjs status",
    "cockpit:config": "node scripts/cockpit/cli.mjs config",
    "cockpit:logs": "node scripts/cockpit/cli.mjs logs",
    "cockpit:help": "node scripts/cockpit/cli.mjs help",
    "cockpit:dhan": "node scripts/cockpit/cli.mjs dhan",
    "cockpit:zerodha": "node scripts/cockpit/cli.mjs zerodha",
    "cockpit:gate": "node scripts/cockpit/cli.mjs gate",
    "cockpit:rotate-topic": "node scripts/cockpit/cli.mjs rotate-topic",

    "cache:warm": "node scripts/warm-cache.mjs",
    "cache:warm:charts": "node scripts/warm-chart-cache.mjs",
    "cache:sync": "node scripts/sync-cache-repo.mjs",

    "worker:keys:rotate": "bash scripts/rotate-keys.sh",
    "worker:kv:audit": "bash scripts/kv-audit.sh",

    "prepare": "git config core.hooksPath .git-hooks"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "hono": "^4.12.18",
    "lightweight-charts": "^5.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.0.2",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  }
}
